{
  "name": "azure-environment-reviewer",
  "version": "1.0.0-beta.1",
  "description": "Open-source Azure security audit tool — live-streamed scans across 9 domains with AI-powered report generation and PDF/DOCX export.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch --watch-path=./server.js --watch-path=./src --watch-path=./public server.js",
    "migrate:sections": "node src/utils/migrateReviewSections.js",
    "test": "node test/findingEngine.test.js"
  },
  "keywords": ["azure", "security", "audit", "cloud", "devsecops"],
  "author": "AzureReview Team",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
