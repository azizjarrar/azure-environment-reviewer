# ── Server ────────────────────────────────────────────────────────────────────
PORT=3007
NODE_ENV=development

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string

# Optional: separate key for encrypting Azure credentials at rest.
# If omitted, SESSION_SECRET is used as the encryption key instead.
ENCRYPTION_KEY=change_this_to_another_long_random_string

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/azure-review
# Local:         mongodb://localhost:27017/azure-review
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/azure-review

# ── AI Report Generation (optional) ──────────────────────────────────────────
# Required only for the AI Report feature. The tool is fully functional without it.
# Setup: https://ai.azure.com → create a project → deploy a model → create an agent
PROJECT_ENDPOINT=https://<your-project>.region.inference.ai.azure.com
AGENT_NAME=ai-azure-report-generator

# ── Dev Auto-fill (optional, development only) ────────────────────────────────
# These are NOT how the app stores credentials — Azure credentials are saved
# encrypted in MongoDB via the Settings page.
# Setting these simply auto-fills the add-credential form during local dev so
# you don't have to type GUIDs manually. Endpoint returns 404 in production.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
